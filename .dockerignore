# Git and IDE (do not copy into image)
.git
.gitignore
.gitattributes
.cursor
.idea
.vscode
*.swp
*.swo

# Dependencies (reinstalled in container)
/vendor
/node_modules
npm-debug.log*
yarn-error.log*

# Laravel runtime (mounted at run time, not needed in image)
storage/*.key
storage/logs
storage/framework/cache/data
storage/framework/sessions
storage/framework/views
storage/app/public

# Bootstrap cache (rebuilt in container)
bootstrap/cache

# Env and secrets (injected at run time)
.env
.env.*

# Tests and dev tooling (not needed in app image)
tests
.phpunit.result.cache
phpunit.xml
.phpunit.cache
coverage

# Docs and infra (not needed in image)
docs
infra
*.md

# Docker (avoid recursive copy)
Dockerfile*
docker-compose*.yml
.dockerignore

# Misc
.DS_Store
Thumbs.db
*.log
*.sqlite
*.sqlite-journal
