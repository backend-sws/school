{
    "$schema": "https://www.schemastore.org/package.json",
    "version": "2.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "types": "tsc --noEmit",
        "podman:dev": "podman compose up -d --build",
        "podman:stop": "podman compose down",
        "podman:logs": "concurrently -n app,nginx,postgres,vite,reverb -c blue,green,yellow,magenta,cyan \"podman compose logs -f app\" \"podman compose logs -f nginx\" \"podman compose logs -f postgres\" \"podman compose logs -f vite\" \"podman compose logs -f reverb\""
    },
    "devDependencies": {
