# =============================================================================
# Environment Configuration Example
# =============================================================================
# Copy this file to .env and configure for your environment
# =============================================================================

# Docker build: optional Alpine mirror override (host or full URL both supported).
# Examples: mirror.leaseweb.com | https://mirror.leaseweb.com | mirror.aarnet.edu.au/alpine
# DOCKER_ALPINE_MIRROR=mirror.leaseweb.com

APP_NAME="Rishi Vidya"
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# EMS domain – main app URL (links, callbacks, session). Local: use your dev URL; production: e.g. https://ems.sutracode.in
APP_URL=http://127.0.0.1:8000

# SaaS Subdomain Session Sharing
# Uncomment and set your main domain with a leading dot to allow sessions across subdomains (e.g. school1.rishividya.com)
# SESSION_DOMAIN=.rishividya.com

# CORS – comma-separated origins for /broadcasting/auth (Echo/realtime). Defaults include APP_URL and Vite dev port.
# CORS_ALLOWED_ORIGINS=http://localhost:38088,http://localhost:35173

# Docker/Podman host ports (avoid "proxy already running" by using distinct ports)
APP_PORT=38088
POSTGRES_HOST_PORT=35432
ADMINER_PORT=38090
VITE_PORT=35173
REVERB_PORT=38080
REDIS_PORT=36379
DOCS_PORT=38091

# API Configuration
API_VERSION=v1

# =============================================================================
# EMS (Education Management System) – Institution scope
# =============================================================================
EMS_DEFAULT_INSTITUTION_ID=1
EMS_MULTI_INSTITUTION_MODE=false
# When institution type cannot be resolved from DB: school|college|coaching|university
EMS_DEFAULT_INSTITUTION_TYPE=school
EMS_DEFAULT_INSTITUTION_DOMAIN=school
# Path to institutions JSON for domain-based resolution (id, type, etc. per domain).
# Local/Podman: use storage path so app loads correct institution for Host (localhost, school.localhost, etc.)
INSTITUTIONS_CONFIG_PATH=storage/app/institutions-config.local.json

# Super Admin (used only by SuperAdminSeeder - set before running db:seed)
SUPERADMIN_EMAIL=sutracodehq@gmail.com
SUPERADMIN_PASSWORD=sutracode123
# SUPERADMIN_NAME=Super Admin

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pds_education
DB_USERNAME=postgres
DB_PASSWORD=secret

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Session & Cache
# =============================================================================
# Use "database" for session-locked college context (active_college_id stored in sessions table)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=auth_session
CACHE_DRIVER=file
QUEUE_CONNECTION=database

# =============================================================================
# Mail (configure as needed)
# =============================================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Broadcasting (Real-time notifications)
# =============================================================================
# For shared hosting SaaS, we use "pusher" instead of "reverb" to avoid daemon requirement.
BROADCAST_CONNECTION=pusher

# Pusher Credentials (get from pusher.com)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_key
PUSHER_APP_SECRET=your_pusher_secret
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap2

# Frontend (Vite) – Broadcast client configuration
VITE_APP_URL="${APP_URL}"
VITE_BROADCAST_CONNECTION="${BROADCAST_CONNECTION}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Web Push (VAPID) – generate with: php artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# =============================================================================
# Cloudflare R2 (file uploads - sliders, gallery, settings images)
# =============================================================================
# Get credentials: Cloudflare Dashboard > R2 > Manage R2 API Tokens > Create API Token
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=a7898ad49e26ed35ac595cdced2bdbac
R2_SECRET_ACCESS_KEY=4c2bc020ae54cf790427a35d22ca1b269f5a2c0dcd3e6502e3031ab9401397eb
R2_ENDPOINT=https://05432e110559ff6298b2fde4e6c68c01.r2.cloudflarestorage.com/collegemanagement
R2_BUCKET=collegemanagement
R2_REGION=auto

# =============================================================================
# Vite Dev Server (for Docker development)
# =============================================================================
VITE_DEV_SERVER_URL=http://localhost:35173

# =============================================================================
# SutraAI Engine (AI Assistant — subscription-gated)
# =============================================================================
SUTRA_AI_URL=http://localhost:8090
SUTRA_AI_API_KEY=
# Google Analytics (GA4)
GA_MEASUREMENT_ID=
